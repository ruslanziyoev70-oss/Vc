import requests
from bs4 import BeautifulSoup

def get_vk_visitors(vk_url, access_token):
    """
    Функция получения списка посетителей страницы ВКонтакте.
    
    Параметры:
     - vk_url (str): URL вашей страницы в формате "https://vk.com/имя_пользователя"
     - access_token (str): Токен доступа ВК API (с правами friends, status)
    """
    
    # Шаг 1: Получаем ID пользователя по короткому имени
    user_id_response = requests.get(
        f"https://api.vk.com/method/users.get?user_ids={vk_url.split('/')[-1]}&access_token={access_token}&v=5.131"
    )
    user_id = user_id_response.json()['response'][0]['id']
    
    # Шаг 2: Получаем список посетителей
    visitors_response = requests.get(
        f"https://api.vk.com/method/friends.getLastSeen?user_id={user_id}&access_token={access_token}&v=5.131"
    )
    
    # Обработка данных
    visitors_data = []
    for visitor in visitors_response.json()['response']['items']:
        visitors_data.append({
            'visitor_id': visitor['id'],
            'last_seen_time': visitor['last_seen'].get('time', 'Не указано'),
            'platform': visitor['last_seen'].get('platform', 0)
        })
    
    return visitors_data

# Пример использования:
if __name__ == "__main__":
